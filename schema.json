{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/crslang/crslang/schema.json",
  "title": "CRSLang Configuration Schema",
  "description": "JSON Schema for CRSLang YAML configuration files",
  "type": "object",
  "properties": {
    "global": {
      "$ref": "#/$defs/DefaultConfigs"
    },
    "directivelist": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DirectiveList"
      }
    }
  },
  "$defs": {
    "DefaultConfigs": {
      "type": "object",
      "description": "Global default configuration applied to all rules",
      "properties": {
        "version": {
          "type": "string",
          "description": "Default version for all rules"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Default tags for all rules"
        }
      },
      "additionalProperties": false
    },
    "DirectiveList": {
      "type": "object",
      "description": "A group of directives with an identifier",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this directive group"
        },
        "directives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SeclangDirective"
          }
        },
        "marker": {
          "$ref": "#/$defs/ConfigurationDirective"
        }
      },
      "additionalProperties": false
    },
    "SeclangDirective": {
      "oneOf": [
        { "$ref": "#/$defs/CommentDirective" },
        { "$ref": "#/$defs/ConfigurationDirective" },
        { "$ref": "#/$defs/DefaultAction" },
        { "$ref": "#/$defs/RuleWithCondition" },
        { "$ref": "#/$defs/RemoveRuleDirective" },
        { "$ref": "#/$defs/UpdateTargetDirective" },
        { "$ref": "#/$defs/UpdateActionDirective" }
      ]
    },
    "CommentDirective": {
      "type": "object",
      "description": "A comment directive",
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "comment"
        },
        "comment": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ConfigurationDirective": {
      "type": "object",
      "description": "A configuration directive (SecAudit, SecRequest, etc.)",
      "required": ["kind", "name", "parameter"],
      "properties": {
        "kind": {
          "const": "configuration"
        },
        "comment": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/ConfigurationDirectiveType"
        },
        "parameter": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ConfigurationDirectiveType": {
      "type": "string",
      "enum": [
        "SecAuditEngine",
        "SecAuditLog",
        "SecAuditLog2",
        "SecAuditLogFormat",
        "SecAuditLogParts",
        "SecAuditLogStorageDir",
        "SecAuditLogDirMode",
        "SecAuditLogFileMode",
        "SecAuditLogRelevantStatus",
        "SecAuditLogType",
        "SecUploadDir",
        "SecUploadKeepFiles",
        "SecUploadFileLimit",
        "SecUploadFileMode",
        "SecTmpSaveUploadedFiles",
        "SecRequestBodyAccess",
        "SecRequestBodyLimit",
        "SecRequestBodyInMemoryLimit",
        "SecRequestBodyNoFilesLimit",
        "SecRequestBodyLimitAction",
        "SecRequestBodyJsonDepthLimit",
        "SecResponseBodyAccess",
        "SecResponseBodyLimit",
        "SecResponseBodyMimeType",
        "SecResponseBodyMimeTypesClear",
        "SecResponseBodyLimitAction",
        "SecRuleEngine",
        "SecConnEngine",
        "SecStatusEngine",
        "SecHashEngine",
        "SecAction",
        "SecArgumentsLimit",
        "SecArgumentSeparator",
        "SecCacheTransformations",
        "SecChrootDir",
        "SecCollectionTimeout",
        "SecComponentSignature",
        "SecConnReadStateLimit",
        "SecConnWriteStateLimit",
        "SecContentInjection",
        "SecCookieFormat",
        "SecCookieV0Separator",
        "SecDataDir",
        "SecDefaultAction",
        "SecDisableBackendCompression",
        "SecDebugLog",
        "SecDebugLogLevel",
        "SecGeoLookupDb",
        "SecGsbLookupDb",
        "SecGuardianLog",
        "SecHashKey",
        "SecHashMethodPm",
        "SecHashMethodRx",
        "SecHashParam",
        "SecHttpBlKey",
        "SecInterceptOnError",
        "SecMarker",
        "SecPcreMatchLimit",
        "SecPcreMatchLimitRecursion",
        "SecPdfProtect",
        "SecPdfProtectMethod",
        "SecPdfProtectSecret",
        "SecPdfProtectTimeout",
        "SecPdfProtectTokenName",
        "SecReadStateLimit",
        "SecWriteStateLimit",
        "SecRemoteRules",
        "SecRemoteRulesFailAction",
        "SecRequestBodyJsonDepthLimit",
        "SecRule",
        "SecRuleInheritance",
        "SecRulePerfTime",
        "SecRuleRemoveById",
        "SecRuleRemoveByMsg",
        "SecRuleRemoveByTag",
        "SecRuleScript",
        "SecRuleUpdateActionById",
        "SecRuleUpdateTargetById",
        "SecRuleUpdateTargetByMsg",
        "SecRuleUpdateTargetByTag",
        "SecServerSignature",
        "SecStreamInBodyInspection",
        "SecStreamOutBodyInspection",
        "SecTmpDir",
        "SecUnicodeCodePage",
        "SecUnicodeMapFile",
        "SecWebAppId",
        "SecXmlExternalEntity"
      ]
    },
    "DefaultAction": {
      "type": "object",
      "description": "Default action for a phase",
      "required": ["actions"],
      "properties": {
        "kind": {
          "const": "defaultaction"
        },
        "metadata": {
          "$ref": "#/$defs/OnlyPhaseMetadata"
        },
        "transformations": {
          "$ref": "#/$defs/TransformationList"
        },
        "actions": {
          "$ref": "#/$defs/SeclangActions"
        }
      },
      "additionalProperties": false
    },
    "RuleWithCondition": {
      "type": "object",
      "description": "A rule with conditions (SecRule, SecAction, or SecRuleScript)",
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "rule"
        },
        "metadata": {
          "$ref": "#/$defs/SecRuleMetadata"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Condition"
          }
        },
        "actions": {
          "$ref": "#/$defs/SeclangActions"
        },
        "chainedRule": {
          "$ref": "#/$defs/ChainedRule"
        }
      },
      "additionalProperties": false
    },
    "ChainedRule": {
      "type": "object",
      "description": "A chained rule",
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "rule"
        },
        "metadata": {
          "$ref": "#/$defs/SecRuleMetadata"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Condition"
          }
        },
        "actions": {
          "$ref": "#/$defs/SeclangActions"
        },
        "chainedRule": {
          "$ref": "#/$defs/ChainedRule"
        }
      },
      "additionalProperties": false
    },
    "Condition": {
      "type": "object",
      "description": "A rule condition",
      "properties": {
        "variables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Variable"
          }
        },
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Collection"
          }
        },
        "operator": {
          "$ref": "#/$defs/Operator"
        },
        "transformations": {
          "$ref": "#/$defs/TransformationList"
        },
        "always-match": {
          "type": "boolean",
          "description": "For SecAction conditions"
        },
        "script": {
          "type": "string",
          "description": "Script path for SecRuleScript conditions"
        }
      },
      "additionalProperties": false
    },
    "Variable": {
      "oneOf": [
        {
          "type": "string",
          "$ref": "#/$defs/VariableName"
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "$ref": "#/$defs/VariableName"
            },
            "excluded": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "VariableName": {
      "type": "string",
      "enum": [
        "ARGS",
        "ARGS_COMBINED_SIZE",
        "ARGS_GET",
        "ARGS_GET_NAMES",
        "ARGS_NAMES",
        "ARGS_POST",
        "ARGS_POST_NAMES",
        "AUTH_TYPE",
        "DURATION",
        "ENV",
        "FILES",
        "FILES_COMBINED_SIZE",
        "FILES_NAMES",
        "FILES_SIZES",
        "FILES_TMPNAMES",
        "FILES_TMP_CONTENT",
        "FULL_REQUEST",
        "FULL_REQUEST_LENGTH",
        "GEO",
        "GLOBAL",
        "HIGHEST_SEVERITY",
        "INBOUND_DATA_ERROR",
        "IP",
        "MATCHED_VAR",
        "MATCHED_VARS",
        "MATCHED_VAR_NAME",
        "MATCHED_VARS_NAMES",
        "MODSEC_BUILD",
        "MULTIPART_BOUNDARY_QUOTED",
        "MULTIPART_BOUNDARY_WHITESPACE",
        "MULTIPART_CRLF_LF_LINES",
        "MULTIPART_DATA_AFTER",
        "MULTIPART_DATA_BEFORE",
        "MULTIPART_FILE_LIMIT_EXCEEDED",
        "MULTIPART_HEADER_FOLDING",
        "MULTIPART_INVALID_HEADER_FOLDING",
        "MULTIPART_INVALID_PART",
        "MULTIPART_INVALID_QUOTING",
        "MULTIPART_LF_LINE",
        "MULTIPART_MISSING_SEMICOLON",
        "MULTIPART_NAME",
        "MULTIPART_PART_HEADERS",
        "MULTIPART_STRICT_ERROR",
        "MULTIPART_UNMATCHED_BOUNDARY",
        "OUTBOUND_DATA_ERROR",
        "PATH_INFO",
        "PERF_ALL",
        "PERF_COMBINED",
        "PERF_GC",
        "PERF_LOGGING",
        "PERF_PHASE1",
        "PERF_PHASE2",
        "PERF_PHASE3",
        "PERF_PHASE4",
        "PERF_PHASE5",
        "PERF_RULES",
        "PERF_SREAD",
        "PERF_SWRITE",
        "QUERY_STRING",
        "REMOTE_ADDR",
        "REMOTE_HOST",
        "REMOTE_PORT",
        "REMOTE_USER",
        "REQBODY_ERROR",
        "REQBODY_ERROR_MSG",
        "REQBODY_PROCESSOR",
        "REQBODY_PROCESSOR_ERROR",
        "REQBODY_PROCESSOR_ERROR_MSG",
        "REQUEST_BASENAME",
        "REQUEST_BODY",
        "REQUEST_BODY_LENGTH",
        "REQUEST_COOKIES",
        "REQUEST_COOKIES_NAMES",
        "REQUEST_FILENAME",
        "REQUEST_HEADERS",
        "REQUEST_HEADERS_NAMES",
        "REQUEST_LINE",
        "REQUEST_METHOD",
        "REQUEST_PROTOCOL",
        "REQUEST_URI",
        "REQUEST_URI_RAW",
        "RESOURCE",
        "RESPONSE_BODY",
        "RESPONSE_CONTENT_LENGTH",
        "RESPONSE_CONTENT_TYPE",
        "RESPONSE_HEADERS",
        "RESPONSE_HEADERS_NAMES",
        "RESPONSE_PROTOCOL",
        "RESPONSE_STATUS",
        "RULE",
        "SCRIPT_BASENAME",
        "SCRIPT_FILENAME",
        "SCRIPT_GID",
        "SCRIPT_GROUPNAME",
        "SCRIPT_MODE",
        "SCRIPT_UID",
        "SCRIPT_USERNAME",
        "SDBM_DELETE_ERROR",
        "SERVER_ADDR",
        "SERVER_NAME",
        "SERVER_PORT",
        "SESSION",
        "SESSIONID",
        "STATUS_LINE",
        "STREAM_INPUT_BODY",
        "STREAM_OUTPUT_BODY",
        "TIME",
        "TIME_DAY",
        "TIME_EPOCH",
        "TIME_HOUR",
        "TIME_MIN",
        "TIME_MON",
        "TIME_SEC",
        "TIME_WDAY",
        "TIME_YEAR",
        "TX",
        "UNIQUE_ID",
        "URLENCODED_ERROR",
        "USER",
        "USERID",
        "USERAGENT_IP",
        "WEBAPPID",
        "WEBSERVER_ERROR_LOG",
        "XML"
      ]
    },
    "Collection": {
      "type": "object",
      "description": "A data collection",
      "properties": {
        "name": {
          "$ref": "#/$defs/CollectionName"
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludeds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "count": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "CollectionName": {
      "type": "string",
      "enum": [
        "ARGS",
        "ARGS_GET",
        "ARGS_GET_NAMES",
        "ARGS_NAMES",
        "ARGS_POST",
        "ARGS_POST_NAMES",
        "ENV",
        "FILES",
        "GEO",
        "GLOBAL",
        "IP",
        "MATCHED_VARS",
        "MATCHED_VARS_NAMES",
        "MULTIPART_PART_HEADERS",
        "PERF_RULES",
        "REQUEST_COOKIES",
        "REQUEST_COOKIES_NAMES",
        "REQUEST_HEADERS",
        "REQUEST_HEADERS_NAMES",
        "RESOURCE",
        "RESPONSE_HEADERS",
        "RESPONSE_HEADERS_NAMES",
        "RULE",
        "SESSION",
        "TX",
        "USER",
        "XML"
      ]
    },
    "Operator": {
      "type": "object",
      "description": "A condition operator",
      "properties": {
        "negate": {
          "type": "boolean",
          "description": "Negate the operator result"
        },
        "rx": {
          "type": "string",
          "description": "Regular expression pattern"
        },
        "rxGlobal": {
          "type": "string",
          "description": "Global regular expression pattern"
        },
        "eq": {
          "type": ["string", "integer"],
          "description": "Equal comparison"
        },
        "streq": {
          "type": "string",
          "description": "String equality comparison"
        },
        "lt": {
          "type": ["string", "integer"],
          "description": "Less than comparison"
        },
        "le": {
          "type": ["string", "integer"],
          "description": "Less than or equal comparison"
        },
        "gt": {
          "type": ["string", "integer"],
          "description": "Greater than comparison"
        },
        "ge": {
          "type": ["string", "integer"],
          "description": "Greater than or equal comparison"
        },
        "within": {
          "type": "string",
          "description": "Value within list"
        },
        "contains": {
          "type": "string",
          "description": "Contains substring"
        },
        "containsWord": {
          "type": "string",
          "description": "Contains word"
        },
        "beginsWith": {
          "type": "string",
          "description": "Begins with string"
        },
        "endsWith": {
          "type": "string",
          "description": "Ends with string"
        },
        "pm": {
          "type": ["string", "array"],
          "description": "Phrase match",
          "items": {
            "type": "string"
          }
        },
        "pmf": {
          "type": "string",
          "description": "Phrase match from file"
        },
        "pmFromFile": {
          "type": "string",
          "description": "Phrase match from file"
        },
        "strmatch": {
          "type": "string",
          "description": "String match"
        },
        "validateByteRange": {
          "type": "string",
          "description": "Validate byte range"
        },
        "validateDTD": {
          "type": "string",
          "description": "Validate against DTD"
        },
        "validateHash": {
          "type": "string",
          "description": "Validate hash"
        },
        "validateSchema": {
          "type": "string",
          "description": "Validate against schema"
        },
        "validateUrlEncoding": {
          "type": "string",
          "description": "Validate URL encoding"
        },
        "validateUtf8Encoding": {
          "type": "string",
          "description": "Validate UTF-8 encoding"
        },
        "detectSQLi": {
          "type": "string",
          "description": "Detect SQL injection"
        },
        "detectXSS": {
          "type": "string",
          "description": "Detect XSS"
        },
        "fuzzyHash": {
          "type": "string",
          "description": "Fuzzy hash matching"
        },
        "ipMatch": {
          "type": "string",
          "description": "IP address match"
        },
        "ipMatchF": {
          "type": "string",
          "description": "IP match from file"
        },
        "ipMatchFromFile": {
          "type": "string",
          "description": "IP match from file"
        },
        "geoLookup": {
          "type": "string",
          "description": "Geographic lookup"
        },
        "gsbLookup": {
          "type": "string",
          "description": "Google Safe Browsing lookup"
        },
        "rbl": {
          "type": "string",
          "description": "RBL lookup"
        },
        "inspectFile": {
          "type": "string",
          "description": "Inspect file"
        },
        "rsub": {
          "type": "string",
          "description": "Regex substitution"
        },
        "verifyCC": {
          "type": "string",
          "description": "Verify credit card"
        },
        "verifyCPF": {
          "type": "string",
          "description": "Verify CPF"
        },
        "verifySSN": {
          "type": "string",
          "description": "Verify SSN"
        },
        "verifySVNR": {
          "type": "string",
          "description": "Verify SVNR"
        },
        "unconditionalMatch": {
          "type": "string",
          "description": "Always match"
        }
      },
      "additionalProperties": false
    },
    "TransformationList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Transformation"
      }
    },
    "Transformation": {
      "type": "string",
      "enum": [
        "none",
        "base64Decode",
        "base64DecodeExt",
        "base64Encode",
        "cmdLine",
        "compressWhitespace",
        "cssDecode",
        "escapeSeqDecode",
        "hexDecode",
        "hexEncode",
        "htmlEntityDecode",
        "jsDecode",
        "length",
        "lowercase",
        "md5",
        "normalisePath",
        "normalizePath",
        "normalisePathWin",
        "normalizePathWin",
        "parityEven7bit",
        "parityOdd7bit",
        "parityZero7bit",
        "removeComments",
        "removeCommentsChar",
        "removeNulls",
        "removeWhitespace",
        "replaceComments",
        "replaceNulls",
        "sha1",
        "sqlHexDecode",
        "trim",
        "trimLeft",
        "trimRight",
        "uppercase",
        "urlDecode",
        "urlDecodeUni",
        "urlEncode",
        "utf8toUnicode"
      ]
    },
    "OnlyPhaseMetadata": {
      "type": "object",
      "properties": {
        "comment": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": ["1", "2", "3", "4", "5"]
        }
      },
      "additionalProperties": false
    },
    "SecRuleMetadata": {
      "type": "object",
      "description": "Rule metadata",
      "properties": {
        "comment": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": ["1", "2", "3", "4", "5"]
        },
        "id": {
          "type": "integer",
          "description": "Rule ID"
        },
        "message": {
          "type": "string",
          "description": "Rule message"
        },
        "maturity": {
          "type": "string",
          "description": "Rule maturity level"
        },
        "revision": {
          "type": "string",
          "description": "Rule revision"
        },
        "severity": {
          "type": "string",
          "enum": [
            "EMERGENCY",
            "ALERT",
            "CRITICAL",
            "ERROR",
            "WARNING",
            "NOTICE",
            "INFO",
            "DEBUG"
          ],
          "description": "Rule severity"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Rule tags"
        },
        "version": {
          "type": "string",
          "description": "Rule version"
        }
      },
      "additionalProperties": false
    },
    "SeclangActions": {
      "type": "object",
      "description": "Rule actions",
      "properties": {
        "disruptive": {
          "$ref": "#/$defs/DisruptiveAction"
        },
        "non-disruptive": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonDisruptiveAction"
          }
        },
        "flow": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FlowAction"
          }
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DataAction"
          }
        }
      },
      "additionalProperties": false
    },
    "DisruptiveAction": {
      "type": "string",
      "enum": [
        "allow",
        "block",
        "deny",
        "drop",
        "pass",
        "pause",
        "proxy",
        "redirect"
      ]
    },
    "NonDisruptiveAction": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "auditlog",
            "capture",
            "log",
            "multiMatch",
            "noauditlog",
            "nolog"
          ]
        },
        {
          "type": "object",
          "properties": {
            "append": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "ctl": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "deprecatevar": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "exec": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "expirevar": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "initcol": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "logdata": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "prepend": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "sanitisearg": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "sanitisematched": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "sanitisematchedbytes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "sanitiserequestheader": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "sanitiseresponseheader": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "setuid": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "setrsc": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "setsid": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "setenv": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "$ref": "#/$defs/SetvarAction"
        }
      ]
    },
    "SetvarAction": {
      "type": "object",
      "description": "Set variable action",
      "properties": {
        "setvar": {
          "oneOf": [
            {
              "type": "array",
              "description": "Simple format: array of key-value assignments (defaults to TX collection with = operation)",
              "items": {
                "type": "object",
                "minProperties": 1,
                "maxProperties": 1,
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            {
              "type": "object",
              "description": "Complex format: explicit collection, operation, and assignments",
              "properties": {
                "collection": {
                  "$ref": "#/$defs/CollectionName"
                },
                "operation": {
                  "type": "string",
                  "enum": ["=", "=+", "=-"]
                },
                "assignments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "minProperties": 1,
                    "maxProperties": 1,
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "required": ["setvar"],
      "additionalProperties": false
    },
    "FlowAction": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["chain"]
        },
        {
          "type": "object",
          "properties": {
            "skip": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "skipAfter": {
              "type": "string"
            }
